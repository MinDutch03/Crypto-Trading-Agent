# =============================================================================
# Crypto Trading Agent — environment template
# Copy to `.env` and fill in. NEVER commit the real .env file.
# =============================================================================

# --- LLM (Google ADK / Gemini via Google AI Studio) ---
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
ADK_MODEL=gemini-2.5-flash

# --- Binance TESTNET keys (used for ALL order placement) ---
# Create at https://testnet.binance.vision/  (Spot testnet)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- Binance LIVE keys (READ-ONLY — used only for real market data) ---
# IMPORTANT: when creating these keys, DISABLE trading & withdrawals.
# Leave blank to use public market data endpoints (no auth needed for prices).
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# --- Risk limits (hard guards enforced before any order) ---
RISK_MAX_NOTIONAL_USDT=100          # max value of a single order
RISK_MAX_OPEN_NOTIONAL_USDT=500     # max total open exposure
RISK_MAX_DAILY_LOSS_USDT=50         # daily realised-loss kill switch
RISK_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT
RISK_MAX_ORDERS_PER_DAY=25
TRADING_ENABLED=true                # master kill switch; false = analysis only

# --- Audit ---
AUDIT_LOG_PATH=audit/trades.jsonl
